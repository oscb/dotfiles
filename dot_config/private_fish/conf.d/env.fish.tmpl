# Editors
set -gx MICRO_TRUECOLOR 1
set -gx EDITOR micro
set -gx VISUAL "code --wait"

fish_add_path $HOME/bin

# Mise
fish_add_path $HOME/.local/share/mise/shims
fish_add_path $HOME/.local/bin

# Fzf Catpuccin mocha
set -gx FZF_DEFAULT_OPTS "\
--color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
--color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8"

# Bat Catppuccin Mocha theme
set -gx BAT_THEME "Catppuccin Mocha"

{{- if eq .chezmoi.os "darwin" }}

# Libraries HomeBrew (macOS only)
set -gx LIBRARY_PATH "/opt/homebrew/lib:$LIBRARY_PATH"

# React Debugger
set -gx REACT_EDITOR "code --wait"

# Swift
# set -gx TOOLCHAINS swift

# Android
set -gx JAVA_HOME (/usr/libexec/java_home -v 11)
set -gx ANDROID_HOME $HOME/Library/Android/sdk
set -gx ANDROID_SDK_ROOT $ANDROID_HOME
fish_add_path $ANDROID_HOME/emulator
fish_add_path $ANDROID_HOME/tools
fish_add_path $ANDROID_HOME/tools/bin
fish_add_path $ANDROID_HOME/platform-tools

# Go
set -gx GOPATH $HOME/Projects/Go

# Flutter
fish_add_path $HOME/.pub-cache/bin
{{- end }}

{{- if eq .chezmoi.hostname "infinity" }}

# Custom NAS
set -gx HDD /srv/dev-disk-by-uuid-8b40a0e9-588d-46cd-ba52-a863e550a94b
set -gx RAID /srv/dev-disk-by-id-md-name-infinity-0
set -gx APPDATA /data/docker/appdata
{{- end }}
