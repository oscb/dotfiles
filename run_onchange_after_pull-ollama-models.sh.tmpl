#!/bin/sh
{{ $host := .chezmoi.hostname -}}
{{ if hasKey .ollama.hosts $host -}}
{{ $cfg := index .ollama.hosts $host -}}
# Pull Ollama models this machine ({{ $host }}) depends on. Hashes the model
# list so chezmoi re-runs only when {{ $host }}'s models change.
if command -v ollama >/dev/null 2>&1; then
{{ range $cfg.models -}}
  echo "Pulling {{ . }}..."
  ollama pull {{ . }} || echo "  failed: {{ . }}"
{{ end -}}
else
  echo "ollama not installed, skipping model pull."
fi
{{ else -}}
# No models configured for {{ $host }} in .chezmoidata.yaml; nothing to pull.
:
{{ end -}}
