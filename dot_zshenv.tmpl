# Editors
export MICRO_TRUECOLOR=1
export EDITOR=micro
export VISUAL="code --wait"

export PATH=$PATH:$HOME/bin

# Mise
export PATH="$HOME/.local/share/mise/shims:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# Fzf Catpuccin mocha
export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
--color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8"

# Bat Catppuccin Mocha theme
export BAT_THEME="Catppuccin Mocha"

{{- if eq .chezmoi.os "darwin" }}

# Libraries HomeBrew (macOS only)
export LIBRARY_PATH="/opt/homebrew/lib:$LIBRARY_PATH"

# React Debugger
export REACT_EDITOR="code --wait"

# Swift
# export TOOLCHAINS=swift

# Android
export JAVA_HOME=$(/usr/libexec/java_home -v 11)
export ANDROID_HOME=$HOME/Library/Android/sdk
export ANDROID_SDK_ROOT=$ANDROID_HOME
export PATH=$PATH:$ANDROID_HOME/emulator
export PATH=$PATH:$ANDROID_HOME/tools
export PATH=$PATH:$ANDROID_HOME/tools/bin
export PATH=$PATH:$ANDROID_HOME/platform-tools

# Go
export GOPATH=$HOME/Projects/Go

# Flutter
export PATH=$PATH:$HOME/.pub-cache/bin
{{- end }}

{{- if eq .chezmoi.hostname "infinity" }}

# Custom NAS
export HDD=/srv/dev-disk-by-uuid-8b40a0e9-588d-46cd-ba52-a863e550a94b
export RAID=/srv/dev-disk-by-id-md-name-infinity-0
export APPDATA=/data/docker/appdata
{{- end }}
